{
  "name": "questflow-2api",
  "version": "2.0.0",
  "description": "将 Questflow AI (next.questflow.ai) 的 TARS 聊天接口反向代理为 OpenAI 兼容格式，带 Web 配置面板",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && node -e \"require('fs').cpSync('src/public','dist/public',{recursive:true})\"",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "lint": "eslint src --ext .ts"
  },
  "keywords": [
    "questflow",
    "2api",
    "openai",
    "reverse-proxy",
    "tars",
    "ai",
    "chat"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "node-fetch": "^2.7.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.10",
    "@types/node-fetch": "^2.6.11",
    "@types/uuid": "^9.0.8",
    "typescript": "^5.5.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
