# Questflow 2API 配置

# 服务端口
PORT=3000

# Questflow 目标 API 基础地址
# 实测端点: https://next.questflow.ai/api/v6/copilot/stream
QUESTFLOW_BASE_URL=https://next.questflow.ai

# Questflow 认证方式
# 支持: cookie, bearer, apikey, custom
# 实测使用 Cookie 认证 (包含 questflow.session-token 和 questflow.csrf-token)
QUESTFLOW_AUTH_TYPE=cookie

# Questflow 认证凭证
# 从浏览器开发者工具复制完整的 Cookie 字符串
# 必须包含 questflow.session-token 和 questflow.csrf-token
QUESTFLOW_AUTH_TOKEN=questflow.csrf-token=xxx; questflow.session-token=eyJ...; _ga=...

# Questflow 聊天接口路径 (实测值)
QUESTFLOW_CHAT_ENDPOINT=/api/v6/copilot/stream

# 是否使用流式输出 (SSE)
STREAM_ENABLED=true

# 请求超时时间 (毫秒)
REQUEST_TIMEOUT=60000

# 日志级别: debug, info, warn, error
LOG_LEVEL=info

# 访问密钥 (可选，设置后调用本服务需要携带此密钥)
# 在请求头中添加: Authorization: Bearer <ACCESS_TOKEN>
ACCESS_TOKEN=

# 代理配置 (如需通过代理访问 Questflow)
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# Questflow 公司 ID (从抓包请求中获取，必填)
QUESTFLOW_COMPANY_ID=6a45d0a566fc71ef1fe81175

# 默认模型 (从抓包请求中获取)
QUESTFLOW_DEFAULT_MODEL=kimi-k2.7-code
